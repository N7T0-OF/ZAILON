{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ZAILON",
  "version": "1.0.0",
  "identifier": "io.github.n7t0of.zailon",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ZAILON",
        "width": 960,
        "height": 580,
        "minWidth": 800,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility"
  }
}
